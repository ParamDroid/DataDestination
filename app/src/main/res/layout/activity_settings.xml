<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:title="@string/settings"
            android:background="#121212"
            android:titleTextColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Card Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1E1E1E"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <!-- Debug Switch -->
                <Switch
                    android:id="@+id/switchDebug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/enable_debug_mode"
                    android:textColor="#E0E0E0"
                    android:padding="8dp"/>

                <!-- API Key Input -->
                <EditText
                    android:id="@+id/editApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/enter_abuseipdb_api_key"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:background="#2A2A2A"
                    android:padding="12dp"
                    android:inputType="textPassword"
                    android:fontFamily="monospace" />
                <!-- Desktop Client Toggle -->
                <Switch
                    android:id="@+id/switchDesktop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable Desktop Client(UNFINSHED)"
                    android:textColor="#E0E0E0"
                    android:padding="8dp"
                    android:layout_marginTop="16dp"/>

                <!-- Desktop IP -->
                <EditText
                    android:id="@+id/editDesktopIp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Desktop IP (e.g. 192.168.1.5)"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:background="#2A2A2A"
                    android:padding="12dp"
                    android:inputType="text"/>

                <!-- Desktop Port -->
                <EditText
                    android:id="@+id/editDesktopPort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Port (default 9000)"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:background="#2A2A2A"
                    android:padding="12dp"
                    android:inputType="number"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>