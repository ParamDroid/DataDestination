<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="@color/dd_success_soft" />
            <stroke
                android:width="2dp"
                android:color="@color/dd_success" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/dd_surface_raised" />
            <stroke
                android:width="2dp"
                android:color="@color/dd_accent" />
        </shape>
    </item>
</selector>
